# ════════════════════════════════════════════
#   BOT MOVISTAR — ARCHIVO DE CONFIGURACIÓN
#   Copia esto como ".env" y llena tus datos
# ════════════════════════════════════════════

# ── GOOGLE SHEETS ─────────────────────────
# Saca el ID de la URL de tu sheet:
# 
SPREADSHEET_ID=1G-gdOtzreHCknpYdB-jnZluAnfYO1IYGJUZ6KsLzWg0

# Nombre exacto de la pestaña (tab inferior)
SHEET_NAME=REGISTROS

# Columna del número telefónico DN (letra)
PHONE_COLUMN=B

# Columna donde el bot escribe el resultado
STATUS_COLUMN=J

# Primera fila de datos (fila 1 = encabezados)
START_ROW=2

# Días hacia atrás para filtrar ventas
WINDOW_DAYS=12

# ── CREDENCIALES GOOGLE ───────────────────
# Ruta al archivo credentials.json
# Debe estar en la MISMA carpeta que este .env
GOOGLE_CREDENTIALS_PATH=./credentials.json

# ── VALIDACIÓN ────────────────────────────
# Cuántas veces validar cada número (mín. recomendado: 3)
VERIFICATION_ROUNDS=3

# Espera entre cada consulta al portal (ms)
DELAY_MS=3500

# Tiempo máximo esperando una respuesta del portal (ms)
TIMEOUT_MS=20000

# Reintentos si el portal falla o no responde
MAX_RETRIES=3

# ── NAVEGADOR ─────────────────────────────
# false = ventana visible (úsalo primero para depurar)
# true  = sin ventana (producción)
HEADLESS=false

# Tabs en paralelo (NO subas de 1 para evitar bloqueos)
CONCURRENT=1
