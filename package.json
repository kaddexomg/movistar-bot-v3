    "test:numero":    "node src/test-numero.js"
  },
  "dependencies": {
    "puppeteer":        "^21.0.0",
    "googleapis":       "^140.0.0",
    "google-auth-library": "^9.0.0",
    "dotenv":           "^16.3.1",
    "chalk":            "^4.1.2",
    "cli-progress":     "^3.12.0",
    "p-limit":          "^3.1.0"
  },
  "engines": { "node": ">=18.0.0" }
}
