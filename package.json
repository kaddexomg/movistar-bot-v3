{
  "name": "movistar-validator-bot",
  "version": "3.0.0",
  "description": "Bot de validación de ventas Movistar MX — hoja REGISTROS",
  "main": "index.js",
  "scripts": {
    "start":          "node index.js",
    "headless":       "node index.js --headless",
    "debug":          "node index.js --debug",
    "force":          "node index.js --force",
    "diagnostico":    "node src/diagnostico.js",
